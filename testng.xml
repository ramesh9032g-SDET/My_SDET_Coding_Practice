        <listener class-name="com.epam.reportportal.testng.ReportPortalTestNGListener"/>
    </listeners>
    <test name="RestAssuredTests">
        <classes>
            <class name="org.pratcticeOrg.Tests.Test.RestAssured.TestClass"/>
